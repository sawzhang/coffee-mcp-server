# Starbucks MCP Server Configuration

# Demo mode: use mock data instead of real API calls
DEMO_MODE=true

# Backend URL (internal network, behind Kong)
# In production, MCP Adapter calls backend directly, NOT through Kong
BACKEND_BASE_URL=http://openapi-platform.internal:8080

# MCP Server
HOST=0.0.0.0
PORT=9000

# Logging
LOG_LEVEL=INFO
