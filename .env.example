# Starbucks MCP Server Configuration

# Starbucks Open Platform Credentials (HMAC signing)
SBUX_APP_KEY=your_app_key_here
SBUX_APP_SECRET=your_app_secret_here

# Open Platform Base URL
SBUX_API_BASE_URL=https://openapi.starbucks.com.cn

# MCP Server
HOST=0.0.0.0
PORT=8000

# LLM Configuration (for semantic formatting enhancement)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com
LLM_MODEL=gpt-4o-mini

# Demo mode: use mock data instead of real API
DEMO_MODE=true

# Logging
LOG_LEVEL=INFO
